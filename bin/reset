#!/usr/bin/env bash

set -e
ROOT="$(dirname ${BASH_SOURCE[0]})/.."

docker compose -f "${ROOT}/docker-compose.dev.yml" stop ckan-dev ckan-worker
docker compose -f "${ROOT}/docker-compose.dev.yml" rm -f ckan-dev ckan-worker

docker volume rm -f ckan_storage || true
docker volume rm -f pip_cache || true
docker volume rm -f site_packages || true
docker volume rm -f local_bin || true
docker volume rm -f home_dir || true

docker compose -f "${ROOT}/docker-compose.dev.yml" up -d --build ckan-dev ckan-worker